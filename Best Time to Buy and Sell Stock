class Solution {
    public int maxProfit(int[] prices) {
        int n = prices.length;
        int maxProfit=0;
        int bestBuy= prices[0];
        for(int i =1;i<n;i++){
            int currProfit=prices[i]-bestBuy;
            if(currProfit>maxProfit){
                maxProfit=currProfit;
            }
            if(prices[i]<bestBuy){
            bestBuy=prices[i];
            }
         }
        return maxProfit;
    } 
}

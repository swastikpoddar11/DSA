class Solution {
    public int[] twoSum(int[] nums, int target) {
        HashMap<Integer,Integer> hm=new HashMap<Integer,Integer>();
        for(int i =0;i<nums.length;i++){
            int second=target-nums[i];
            if(hm.containsKey(second)){
                int[] arr={hm.get(second),i};
                return arr;
            }
            hm.put(nums[i],i);
        }
        return null;
    }
}
